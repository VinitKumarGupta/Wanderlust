<%- layout("/layouts/boilerplate") %>
<div class="row mt-5 mb-5">
    <h1 class="col-11 col-sm-8 col-md-6 offset-sm-2 offset-md-3">Login</h1>
    <div class="col-11 col-sm-8 col-md-6 offset-sm-2 offset-md-3">
        <form action="/login" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input
                    type="text"
                    name="username"
                    id="username"
                    class="form-control"
                    required
                />
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <div class="position-relative">
                    <input
                        type="password"
                        name="password"
                        id="password"
                        class="form-control"
                        required
                        style="padding-right: 2.5rem;"
                    />
                    <i class="fa-regular fa-eye-slash position-absolute" id="togglePassword" style="right: 15px; top: 50%; transform: translateY(-50%); cursor: pointer; color: #6c757d; font-size: 1.1rem; z-index: 10;"></i>
                </div>
            </div>
            <p>Don't have an account? <a href="/signup" style="text-decoration: none; color: #fe424d;">Signup</a></p>
            <button class="btn btn-success">Login</button>
        </form>
    </div>
</div>
