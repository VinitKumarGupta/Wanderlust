<%- layout("/layouts/boilerplate") %>
<div class="row mt-4 mb-5">
  <h1 class="col-11 col-sm-8 col-md-6 offset-sm-2 offset-md-3 mb-3">SignUp on Wanderlust</h1>
  <div class="col-11 col-sm-8 col-md-6 offset-sm-2 offset-md-3">
    <form action="/signup" method="POST" class="needs-validation" novalidate>
      <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input
          type="text"
          name="username"
          id="username"
          class="form-control"
          required
        />
        <div class="valid-feedback">Looks good!</div>
      </div>
      <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          class="form-control"
          required
        />
      </div>
      <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          class="form-control"
          required
        />
      </div>
      <p>
        Already have an account?
        <a href="/login" style="text-decoration: none; color: #fe424d">Login</a>
      </p>
      <button class="btn btn-success">SignUp</button>
    </form>
  </div>
</div>
